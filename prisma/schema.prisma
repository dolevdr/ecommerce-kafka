generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  COMPLETED
  CREATED
  DELIVERED
  FAILED
  PROCESSING
  SHIPPED
}

enum PaymentStatus {
  COMPLETED
  FAILED
  PENDING
}

enum ReservationStatus {
  FAILED
  PENDING
  RELEASED
  RESERVED
}

enum ShipmentStatus {
  DELIVERED
  DISPATCHED
  FAILED
}

model Order {
  id         Int         @id @default(autoincrement())
  orderId    String      @unique @default(uuid())
  customerId String
  productId  String
  quantity   Int
  status     OrderStatus @default(CREATED)
  createdAt  DateTime    @default(now())

  @@map("orders")
}

model InventoryReservation {
  id        Int               @id @default(autoincrement())
  orderId   String            @unique
  productId String
  quantity  Int
  status    ReservationStatus @default(PENDING)
  createdAt DateTime          @default(now())

  @@map("inventory_reservations")
}

model Payment {
  id         Int           @id @default(autoincrement())
  orderId    String        @unique
  customerId String
  amount     Int
  status     PaymentStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  @@map("payments")
}

model Shipment {
  id             Int            @id @default(autoincrement())
  orderId        String         @unique
  customerId     String
  productId      String
  quantity       Int
  carrier        String
  trackingNumber String
  status         ShipmentStatus @default(DISPATCHED)
  createdAt      DateTime       @default(now())
  deliveredAt    DateTime?

  @@map("shipments")
}
